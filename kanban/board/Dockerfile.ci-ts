# typecheck + tests del paquete @devpablocristo/modules-kanban-board.
FROM node:20.17.0-bookworm-slim
WORKDIR /repo/modules/kanban/board/ts

COPY modules/kanban/board/ts/package.json ./
COPY modules/kanban/board/ts/package-lock.json ./

RUN npm ci --no-audit --no-fund

COPY modules/kanban/board/ts/ ./

RUN npm run typecheck && npm test

CMD ["node", "-e", "console.log('modules-kanban-board OK')"]
