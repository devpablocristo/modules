# typecheck + tests del paquete @devpablocristo/modules-ui-forms.
FROM node:22-bookworm-slim
WORKDIR /repo/modules/ui/forms/ts

COPY modules/ui/forms/ts/package.json ./
COPY modules/ui/forms/ts/package-lock.json ./

RUN npm install --no-audit --no-fund

COPY modules/ui/forms/ts/ ./

RUN npm run typecheck && npm test

CMD ["node", "-e", "console.log('modules-ui-forms OK')"]
