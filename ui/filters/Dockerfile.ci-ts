# typecheck + tests del paquete @devpablocristo/modules-ui-filters.
FROM node:20.17.0-bookworm-slim
WORKDIR /repo/modules/ui/filters/ts

COPY modules/ui/filters/ts/package.json ./
COPY modules/ui/filters/ts/package-lock.json ./

RUN npm ci --no-audit --no-fund

COPY modules/ui/filters/ts/ ./

RUN npm run typecheck && npm test

CMD ["node", "-e", "console.log('modules-ui-filters OK')"]
