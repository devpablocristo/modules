# typecheck + tests del paquete @devpablocristo/modules-crud.
# Build: context = padre de `modules` (mismo layout que pymes + core en Docker).
FROM node:22-bookworm-slim
WORKDIR /repo/modules/crud/ts

COPY modules/crud/ts/package.json ./
COPY core/browser/ts /repo/core/browser/ts

RUN npm install --no-audit --no-fund

COPY modules/crud/ts/ ./

RUN npm run typecheck && npm test

CMD ["node", "-e", "console.log('modules-crud OK')"]
