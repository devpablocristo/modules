{
  "name": "@devpablocristo/modules-crud-ui",
  "version": "0.8.2",
  "private": false,
  "type": "module",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./csv": "./src/csv.ts",
    "./csv-toolbar": "./src/csvToolbarMerge.ts",
    "./surface": "./src/surface.ts",
    "./preferences": "./src/crudUiPreferences.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@devpablocristo/core-browser": "^0.4.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --globals --passWithNoTests tests src",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
